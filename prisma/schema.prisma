generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum GuestOf {
  SVEN
  TINA
}

enum RSVPStatus {
  PENDING
  ATTENDING
  NOT_ATTENDING
}

model Guest {
  id               Int      @id @default(autoincrement())
  name             String
  surname          String
  email            String?   @unique
  drinkPreferences String?  @db.Text
  otherRequests    String?  @db.Text
  guestOf          GuestOf
  rsvpStatus       RSVPStatus @default(PENDING)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
}
